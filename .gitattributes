# Auto-detect text files e normaliza para LF no repo (cada checkout aplica autocrlf local).
* text=auto

# Forçar tratamento como binário (sem normalização CRLF/LF) para evitar corrupção.
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.svg      text
*.eot      binary
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.mp3      binary
*.mp4      binary
*.webm     binary

# Forçar LF em arquivos de shell/config críticos.
*.sh       text eol=lf
*.bash     text eol=lf
Dockerfile text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
